# Backend (Spring Boot) — read at startup
PROSE_JWT_SECRET=change-me-to-a-long-random-hex-string
PROSE_JWT_EXPIRATION=86400000
PROSE_DB_URL=jdbc:postgresql://localhost:5432/mydatabase
PROSE_DB_USERNAME=myuser
PROSE_DB_PASSWORD=change-me
SERVER_PORT=8080

# Docker Compose (PostgreSQL container)
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=change-me
